# Build intermediates only. The EXTRACTED SOURCE is the product and is committed —
# CI cannot regenerate it (that needs Dafny plus a private runtime dependency).
**/bin/
**/obj/
**/target/classes/
**/node_modules/
**/.venv*/
**/__pycache__/
**/*.pyc
**/.build/
*.nupkg
*.snupkg
*.tgz
*.whl
.DS_Store
# C++ route build outputs (regenerable via each route's regenerate.sh / build.sh)
cpp-via-*/build/
cpp-via-*/build-cmake/
cpp-via-*/lib/*.a
cpp-via-*/lib/*.dylib
cpp-via-*/**/target/
cpp-via-*/toolchain/
