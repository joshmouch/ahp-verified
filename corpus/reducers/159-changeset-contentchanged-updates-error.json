              "content": {
                "uri": "content:/a"
              }
            },
            "diff": {
              "added": 5
            }
          }
        }
      ],
      "error": {
        "errorType": "git",
        "message": "new error"
      }
    }
  ],
  "expected": {
    "status": "error",
    "error": {
      "errorType": "git",
      "message": "new error"
    },
    "files": [
      {
