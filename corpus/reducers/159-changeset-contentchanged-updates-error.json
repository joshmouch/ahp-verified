  "initial": {
    "status": "error",
    "error": {
      "errorType": "git",
      "message": "old error"
    },
    "files": [
      {
        "id": "file:///src/old.ts",
        "edit": {
          "after": {
            "uri": "file:///src/old.ts",
            "content": {
              "uri": "content:/old"
            }
          },
          "diff": {
            "added": 1
          }
        }
      }
    ],
    "operations": [
      {
        "id": "make-pr",
        "label": "Create Pull Request",
        "scopes": [
          "changeset"
        ],
        "status": "idle"
