        "enabled": true,
        "children": [
          {
            "type": "skill",
            "id": "skill-1",
            "uri": "https://plugins.example/a#skills/lint",
            "name": "lint"
          },
          {
            "type": "mcpServer",
            "id": "mcp-child",
            "uri": "https://plugins.example/a#mcp/search",
            "name": "Search",
            "enabled": true,
            "state": {
              "kind": "ready"
            },
            "channel": "mcp://search"
          }
        ]
      }
    ]
