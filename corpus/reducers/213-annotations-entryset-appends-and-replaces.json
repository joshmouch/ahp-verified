{
  "description": "annotations/entrySet appends or replaces an entry within an annotation",
  "reducer": "annotations",
  "initial": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "original" }
        ]
      }
    ]
  },
  "actions": [
    {
      "type": "annotations/entrySet",
      "annotationId": "t-1",
      "entry": { "id": "c-2", "text": "second" }
    },
    {
      "type": "annotations/entrySet",
      "annotationId": "t-1",
      "entry": { "id": "c-1", "text": "edited" }
    }
  ],
  "expected": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "edited" },
          { "id": "c-2", "text": "second" }
        ]
      }
    ]
  }
}
