{
  "description": "annotations/entrySet is a no-op when the enclosing annotation is unknown",
  "reducer": "annotations",
  "initial": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "only" }
        ]
      }
    ]
  },
  "actions": [
    {
      "type": "annotations/entrySet",
      "annotationId": "missing",
      "entry": { "id": "c-x", "text": "lost" }
    }
  ],
  "expected": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "only" }
        ]
      }
    ]
  }
}
