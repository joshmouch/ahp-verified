{
  "description": "annotations/entryRemoved drops the matching entry and leaves other entries untouched",
  "reducer": "annotations",
  "initial": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "first" },
          { "id": "c-2", "text": "second" },
          { "id": "c-3", "text": "third" }
        ]
      }
    ]
  },
  "actions": [
    { "type": "annotations/entryRemoved", "annotationId": "t-1", "entryId": "c-2" },
    { "type": "annotations/entryRemoved", "annotationId": "t-1", "entryId": "missing" },
    { "type": "annotations/entryRemoved", "annotationId": "missing", "entryId": "c-1" }
  ],
  "expected": {
    "annotations": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "resolved": false,
        "entries": [
          { "id": "c-1", "text": "first" },
          { "id": "c-3", "text": "third" }
        ]
      }
    ]
  }
}
